# SAIAI release-pair coordinates only. Do not put credentials in this file.
# Copy it to a private operations repository and fill every required value.

RELEASE_ID=

SERVER_SOURCE=
SERVER_IMAGE=ghcr.io/yuns2023/saiai-server@sha256:
SERVER_BINARY_SHA256=

CLIENT_REPOSITORY=yuns2023/saiai-client
CLIENT_SOURCE=
CLIENT_TAG=saiai-v
CLIENT_MANIFEST_SHA256=
CLIENT_SYNC_SCRIPT=
CLIENT_SYNC_SCRIPT_SHA256=
CLIENT_DIR=/var/lib/saiai-server/client-runtime/saiai-cli

PREVIOUS_SERVER_SOURCE=
PREVIOUS_SERVER_IMAGE=
PREVIOUS_CLIENT_SOURCE=
PREVIOUS_CLIENT_TAG=
PREVIOUS_CLIENT_MANIFEST_SHA256=
PREVIOUS_CLIENT_SYNC_SCRIPT=
PREVIOUS_CLIENT_SYNC_SCRIPT_SHA256=

# Private deployment paths belong in the copied operations file, not here.
DEPLOY_DIR=
COMPOSE_FILE=
PREVIOUS_COMPOSE_FILE=
BACKUP_DIR=
RELEASE_RECORD=
EXPECTED_MIGRATION=
GATEWAY_ORIGIN=

# The runbook examples expect gzip-compressed tar archives for these two files.
BACKUP_HASH_MANIFEST=
CLIENT_BACKUP_TAR_GZ=
DATA_BACKUP_TAR_GZ=
POSTGRES_BACKUP=
